# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (required for persistence, auth, and RLS-scoped queries) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co       # Supabase project URL (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                     # Supabase anon/public key (safe to expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key                 # Server-only key; bypasses RLS — never expose to the client

# --- Gemini AI (agent brains) ------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key                              # Google Gemini API key used by all AI agents

# --- Voicebox (local/self-hosted TTS server) --------------------------------
VOICEBOX_URL=http://127.0.0.1:8000                              # Base URL of the Voicebox TTS server (dev: localhost; prod: your hosted instance)
VOICEBOX_PROFILE_ID=                                            # Optional: pin TTS to a specific voice profile ID instead of auto-discovering

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=your-resend-api-key                              # Resend API key for sending outreach/reports; email sending is skipped silently if unset
RESEND_FROM_EMAIL=VELTRIX OS <onboarding@resend.dev>            # Verified sender address/display name for outgoing email
NOTIFY_EMAIL=you@example.com                                    # Owner email used for notifications and as the default account lookup

# --- Obsidian brain sync -----------------------------------------------------
GITHUB_TOKEN=your-github-token                                  # GitHub PAT with repo access, used to sync the Obsidian vault
GITHUB_OBSIDIAN_REPO=owner/repo                                 # GitHub repo (owner/name) hosting the Obsidian vault
OBSIDIAN_VAULT_PATH=/path/to/Veltrix/vault                      # Local filesystem path to the Obsidian vault (used by local sync tooling)

# --- Cron / automation security ----------------------------------------------
CRON_SECRET=a-long-random-secret                                # Shared secret required by autopilot/cron routes in production; requests without it are rejected

# --- Site config --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://your-deployed-domain.com           # Public base URL of the deployed app, used to build absolute links/callbacks
